---
/** 天球坐标系示意:天极、天赤道、黄道、某天体的赤经/赤纬。随语言切换标签。 */
interface Props { caption?: string; }
const en = Astro.url.pathname.startsWith('/en');
const L = en
  ? { cap: 'Celestial sphere: positions are fixed by right ascension (RA) and declination (Dec) relative to the celestial equator.',
      ncp: 'N. celestial pole', scp: 'S. celestial pole', eq: 'Celestial equator', ecl: 'Ecliptic', earth: 'Earth', obj: 'Object P' }
  : { cap: '天球坐标系:以天赤道为基准,用赤经(RA)与赤纬(Dec)定位天体。',
      ncp: '北天极 NCP', scp: '南天极 SCP', eq: '天赤道', ecl: '黄道', earth: '地球', obj: '天体 P' };
const { caption = L.cap } = Astro.props;
---
<figure class="diagram">
  <svg viewBox="0 0 520 380" role="img" aria-label={en ? 'Celestial coordinate system' : '天球坐标系示意图'}>
    <defs>
      <radialGradient id="cs-glow" cx="50%" cy="45%" r="60%">
        <stop offset="0%" stop-color="#1a2350" />
        <stop offset="100%" stop-color="#0a0d1a" />
      </radialGradient>
    </defs>
    <rect width="520" height="380" fill="url(#cs-glow)" rx="12" />
    <circle cx="260" cy="190" r="150" fill="none" stroke="#3a4690" stroke-width="1.5" />
    <line x1="260" y1="20" x2="260" y2="360" stroke="#6b78c8" stroke-width="1" stroke-dasharray="4 4" />
    <text x="268" y="30" fill="#c4cdff" font-size="13">{L.ncp}</text>
    <text x="268" y="358" fill="#c4cdff" font-size="13">{L.scp}</text>
    <ellipse cx="260" cy="190" rx="150" ry="48" fill="none" stroke="#5fe3d2" stroke-width="2" />
    <text x="416" y="186" fill="#5fe3d2" font-size="13" text-anchor="end">{L.eq}</text>
    <g transform="rotate(-23.5 260 190)">
      <ellipse cx="260" cy="190" rx="150" ry="48" fill="none" stroke="#ffd66e" stroke-width="2" stroke-dasharray="6 3" />
    </g>
    <text x="40" y="120" fill="#ffd66e" font-size="13">{L.ecl}</text>
    <circle cx="260" cy="190" r="9" fill="#5e74ff" />
    <text x="244" y="214" fill="#aab4ff" font-size="11" text-anchor="end">{L.earth}</text>
    <circle cx="350" cy="120" r="5" fill="#fff" />
    <text x="358" y="118" fill="#fff" font-size="13">{L.obj}</text>
    <path d="M350 153 A 150 48 0 0 0 350 120" fill="none" stroke="#ff8fa3" stroke-width="2" />
    <text x="356" y="142" fill="#ff8fa3" font-size="12">+Dec</text>
    <path d="M260 142 A 150 48 0 0 1 350 153" fill="none" stroke="#9aa6ff" stroke-width="2" />
    <text x="290" y="138" fill="#9aa6ff" font-size="12">RA →</text>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>
