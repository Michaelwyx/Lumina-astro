---
/** 主题切换:单个按钮在深/浅色间切换,日月图标(替代下拉选项)。 */
---

<starlight-theme-toggle>
  <button type="button" class="theme-toggle" aria-label="切换深色 / 浅色">
    <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
    <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4.2" />
      <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
    </svg>
  </button>
</starlight-theme-toggle>

<script is:inline>
  if (window.StarlightThemeProvider && StarlightThemeProvider.updatePickers) StarlightThemeProvider.updatePickers();
</script>
<script>
  const KEY = 'starlight-theme';
  const pref = () => (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
  const current = () => (document.documentElement.dataset.theme || pref());
  function apply(t: string) {
    document.documentElement.dataset.theme = t;
    try { localStorage.setItem(KEY, t); } catch (e) {}
    const w = window as any;
    if (w.StarlightThemeProvider && w.StarlightThemeProvider.updatePickers) w.StarlightThemeProvider.updatePickers(t);
  }
  class ThemeToggle extends HTMLElement {
    constructor() {
      super();
      this.querySelector('button')?.addEventListener('click', () => {
        apply(current() === 'dark' ? 'light' : 'dark');
      });
    }
  }
  customElements.define('starlight-theme-toggle', ThemeToggle);
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 9px;
    border: 1px solid var(--sl-color-gray-5);
    background: transparent;
    color: var(--sl-color-text);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }
  .theme-toggle:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-4);
  }
  /* 显示当前模式的图标:暗→月,亮→日 */
  :root[data-theme='dark'] .icon-sun { display: none; }
  :root[data-theme='light'] .icon-moon { display: none; }
</style>
